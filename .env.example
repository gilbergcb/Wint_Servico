# ====================================================================
# Configuracao do modulo de Servico (Wint_servico) - ambiente DEV
# Copie para .env e ajuste. NAO versionar o .env.
# ====================================================================

# Modo de conexao do python-oracledb:
#   thin  -> sem Instant Client. EXIGE servidor Oracle 12.1+.
#   thick -> usa Instant Client (init_oracle_client a partir de
#            SVC_ORACLE_CLIENT_LIB_DIR).
#
# ATENCAO (ambiente de TESTE = Oracle 10g 10.2.0.3.0, 32-bit):
#   - thin NAO funciona com 10g  ->  use SVC_DB_MODE=thick no teste.
#   - Para o thick falar com 10g, o Instant Client deve ser 11.2 ou 12.x
#     (NAO 19c, que removeu suporte a servidores 10g).
#   - Como o alvo de build e .exe 64-bit, o Instant Client tambem deve ser
#     64-bit (Windows x64), com oci.dll dentro de SVC_ORACLE_CLIENT_LIB_DIR.
SVC_DB_MODE=thick

# Caminho da pasta do Instant Client (apenas quando SVC_DB_MODE=thick).
# Ex.: C:\oracle\instantclient_12_2  (64-bit, versao 11.2 ou 12.x para falar com 10g)
SVC_ORACLE_CLIENT_LIB_DIR=

# Credenciais para desenvolvimento (ignoradas quando aberto pelo menu Winthor).
SVC_DB_USER=
SVC_DB_PWD=
SVC_DB_DSN=

# Forca o modo dev offline (app abre mesmo sem banco). 1 = ligado.
SVC_DEV_OFFLINE=1

# (Opcional) diretorio com tnsnames.ora / sqlnet.ora.
# TNS_ADMIN=
